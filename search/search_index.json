 \u2b1b Double Black Diamond \u975e\u5e38\u56f0\u96be \u66f4\u9661\u66f4\u5371\u9669 \ud83d\udd3a Triple Black Diamond \u6781\u7aef\u56f0\u96be\uff08\u90e8\u5206\u96ea\u573a\uff09 \u6781\u96be\uff0c\u4ec5\u9650\u4e13\u5bb6"},{"location":"03-%E6%BB%91%E9%9B%AA%E7%9F%A5%E8%AF%86/A-%E5%9C%BA%E5%9C%B0%E7%AF%87/1-%E9%9B%AA%E9%81%93/#_6","title":"\u65e5\u672c","text":"\u989c\u8272 \u96be\u5ea6 \ud83d\udfe2 Green \u521d\u5b66\u8005\uff08\u57fa\u5730\u6216\u7f13\u5761\uff09 \ud83d\udd34 Red \u4e2d\u7ea7\u6ed1\u9053\uff08\u8bb8\u591a\u6ed1\u9053\u4e3a\u6b64\u7ea7\uff09 \u2b1b Black \u4e13\u4e1a/\u4e13\u5bb6"},{"location":"03-%E6%BB%91%E9%9B%AA%E7%9F%A5%E8%AF%86/A-%E5%9C%BA%E5%9C%B0%E7%AF%87/1-%E9%9B%AA%E9%81%93/#_7","title":"\u96ea\u8d28\u7c7b\u522b","text":""},{"location":"03-%E6%BB%91%E9%9B%AA%E7%9F%A5%E8%AF%86/A-%E5%9C%BA%E5%9C%B0%E7%AF%87/1-%E9%9B%AA%E9%81%93/#powder-snow","title":"\u7c89\u96ea(Powder Snow)","text":"<p>\u65b0\u9c9c\u964d\u843d\u3001\u672a\u53d7\u538b\u7684\u96ea\uff0c\u677e\u8f6f\u3001\u8f7b\u76c8\u3001\u5e72\u71e5\uff0c\u4e3b\u8981\u51fa\u73b0\u5728\u65b0\u96ea\u521a\u843d\u53ca\u4f4e\u6e29\u73af\u5883\u4e0b\u3002\u9897\u7c92\u677e\u6563\uff0c\u6ed1\u884c\u65f6\u4f1a\u6709\u50cf\u201c\u6f02\u6d6e\u201d\u7684\u611f\u89c9\uff0c\u662f\u6ed1\u96ea\u8005\u8ffd\u6c42\u7684\u7406\u60f3\u96ea\u51b5\u3002</p>"},{"location":"03-%E6%BB%91%E9%9B%AA%E7%9F%A5%E8%AF%86/A-%E5%9C%BA%E5%9C%B0%E7%AF%87/1-%E9%9B%AA%E9%81%93/#crud-snow","title":"\u4e71\u96ea/\u788e\u96ea(Crud Snow)","text":"<p>\u539f\u672c\u7684\u7c89\u96ea\u88ab\u96ea\u677f\u6216\u6ed1\u884c\u538b\u788e\u540e\u5f62\u6210\u7684\u4e00\u79cd\u53c2\u5dee\u4e0d\u9f50\u7684\u6df7\u5408\u96ea\uff0c\u5e38\u89c1\u4e8e\u7c89\u96ea\u88ab\u5927\u91cf\u6ed1\u8fc7\u540e\u5f62\u6210\u3002\u8868\u9762\u4e0d\u5e73\u3001\u8f6f\u786c\u4e0d\u4e00\uff0c\u65e2\u6709\u7c89\u96ea\u53c8\u6709\u88ab\u538b\u5b9e\u7684\u90e8\u5206\uff0c\u9700\u8981\u8f83\u9ad8\u6280\u5de7\u5e94\u5bf9\u3002</p>"},{"location":"03-%E6%BB%91%E9%9B%AA%E7%9F%A5%E8%AF%86/A-%E5%9C%BA%E5%9C%B0%E7%AF%87/1-%E9%9B%AA%E9%81%93/#crust-snow","title":"\u786c\u58f3\u96ea(Crust Snow)","text":"<p>\u96ea\u8868\u5c42\u7ecf\u5386\u878d\u5316\u518d\u91cd\u65b0\u7ed3\u51b0\u7684\u5faa\u73af\uff0c\u5728\u4e0a\u5c42\u5f62\u6210\u4e00\u5c42\u786c\u800c\u8106\u7684\u58f3\uff0c\u5178\u578b\u5728\u65e5\u7167\u878d\u96ea\u540e\u591c\u95f4\u518d\u51bb\u65f6\u51fa\u73b0\u3002\u6709\u65f6\u8584\u5f97\u5bb9\u6613\u7834\uff0c\u6709\u65f6\u539a\u5230\u53ef\u4ee5\u76f4\u63a5\u6ed1\u8fc7\u3002</p>"},{"location":"03-%E6%BB%91%E9%9B%AA%E7%9F%A5%E8%AF%86/A-%E5%9C%BA%E5%9C%B0%E7%AF%87/1-%E9%9B%AA%E9%81%93/#packedhard-snow","title":"\u538b\u5b9e\u96ea(Packed/Hard Snow)","text":"<p>\u7c89\u96ea\u6216\u8f83\u8f6f\u96ea\u5728\u96ea\u5730\u673a\u68b0\u6574\u7406\u6216\u5927\u91cf\u6ed1\u884c\u540e\u88ab\u538b\u5b9e\uff0c\u5e38\u89c1\u4e8e\u4eba\u5de5\u96ea\u573a\u3002\u8868\u9762\u6bd4\u8f83\u5e73\u6574\u3001\u786c\u5ea6\u8f83\u5927\uff0c\u9002\u5408\u523b\u6ed1\u4f46\u8f83\u6ed1\uff0c\u901f\u5ea6\u5feb\u3002</p>"},{"location":"03-%E6%BB%91%E9%9B%AA%E7%9F%A5%E8%AF%86/A-%E5%9C%BA%E5%9C%B0%E7%AF%87/1-%E9%9B%AA%E9%81%93/#corn-snow","title":"\u9897\u7c92\u96ea(Corn Snow)","text":"<p>\u5728\u53cd\u590d\u201c\u878d\u5316\u2014\u518d\u51bb\u7ed3\u201d\u5faa\u73af\u4e0b\u5f62\u6210\u7684\u96ea\u8d28\uff0c\u96ea\u6676\u9010\u6e10\u53d8\u6210\u5747\u5300\u3001\u5706\u6da6\u3001\u50cf\u7389\u7c73\u7c92\u4e00\u6837\u7684\u9897\u7c92\u3002\u652f\u6491\u6027\u597d\uff0c\u4e0d\u5bb9\u6613\u9677\u677f\uff0c\u8fb9\u5203\u6293\u5730\u7a33\u5b9a\uff0c\u975e\u5e38\u987a\u6ed1\uff0c\u8f6c\u5f2f\u53cd\u9988\u6e05\u6670\u3002</p>"},{"location":"03-%E6%BB%91%E9%9B%AA%E7%9F%A5%E8%AF%86/A-%E5%9C%BA%E5%9C%B0%E7%AF%87/1-%E9%9B%AA%E9%81%93/#iceicy-snow","title":"\u51b0\u72b6\u96ea(Ice/Icy Snow)","text":"<p>\u96ea\u5728\u878d\u5316\u540e\u5b8c\u5168\u7ed3\u51b0\u7684\u7ed3\u679c\uff0c\u5f62\u6210\u975e\u5e38\u575a\u786c\u3001\u5149\u6ed1\u7684\u8868\u9762\u3002\u6ed1\u884c\u65f6\u5bb9\u6613\u6253\u6ed1\uff0c\u5bf9\u521d\u5b66\u8005\u5c24\u4e3a\u5177\u6709\u6311\u6218\u6027\uff0c\u5e38\u7528\u4e8e\u7ecf\u6d4e\u9ad8\u5c71\u6ed1\u96ea\u8d5b\u9053\u3002</p>"},{"location":"03-%E6%BB%91%E9%9B%AA%E7%9F%A5%E8%AF%86/A-%E5%9C%BA%E5%9C%B0%E7%AF%87/1-%E9%9B%AA%E9%81%93/#slushsticky-snow","title":"\u6e7f\u96ea/\u6ce5\u96ea(Slush/Sticky Snow)","text":"<p>\u96ea\u6e29\u63a5\u8fd1\u6216\u8d85\u8fc7\u878d\u70b9\u540e\u5f00\u59cb\u90e8\u5206\u878d\u5316\uff0c\u542b\u6c34\u91cf\u9ad8\u3001\u9ecf\u7a20\u3001\u6c89\u91cd\uff0c\u6625\u5b63\u6216\u6c14\u6e29\u8f83\u9ad8\u65f6\u8f83\u5e38\u89c1\u3002\u6ed1\u884c\u963b\u529b\u5927\u3001\u901f\u5ea6\u6162\uff0c\u5bb9\u6613\u201c\u7c98\u4f4f\u201d\u6ed1\u96ea\u677f\u3002</p>"},{"location":"03-%E6%BB%91%E9%9B%AA%E7%9F%A5%E8%AF%86/A-%E5%9C%BA%E5%9C%B0%E7%AF%87/1-%E9%9B%AA%E9%81%93/#_8","title":"\u5761\u5ea6\u6362\u7b97\u8868","text":"\u03b8 (\u00b0) tan\u03b8 (%) 1 1% 2 3% 3 5% 4 6% 5 8% 6 10% 7 12% 8 14% 9 15% 10 17% 11 19% 12 21% 13 23% 14 24% 15 26% 16 28% 17 30% 18 32% 19 34% 20 36% 21 38% 22 40% 23 42% 24 44% 25 46% 26 48% 27 50% 28 53% 29 55% 30 57%"},{"location":"03-%E6%BB%91%E9%9B%AA%E7%9F%A5%E8%AF%86/B-%E8%A3%85%E5%A4%87%E7%AF%87/1-%E5%8F%8C%E6%9D%BF%E9%9B%AA%E6%9D%BF/","title":"\u53cc\u677f\u96ea\u677f\u7b80\u4ecb","text":""},{"location":"03-%E6%BB%91%E9%9B%AA%E7%9F%A5%E8%AF%86/B-%E8%A3%85%E5%A4%87%E7%AF%87/1-%E5%8F%8C%E6%9D%BF%E9%9B%AA%E6%9D%BF/#_2","title":"\u79cd\u7c7b","text":""},{"location":"03-%E6%BB%91%E9%9B%AA%E7%9F%A5%E8%AF%86/B-%E8%A3%85%E5%A4%87%E7%AF%87/1-%E5%8F%8C%E6%9D%BF%E9%9B%AA%E6%9D%BF/#_3","title":"\u9053\u5185\u677f/\u5361\u5bbe\u677f","text":"<p>\u677f\u5934\u7fd8\u8d77\uff0c\u677f\u8170\u76f8\u5bf9\u7a84\u7ec6\uff0c\u677f\u5c3e\u8d8b\u5411\u5e73\u76f4\u3002\u5c0f\u56de\u8f6c\u534a\u5f84\u66f4\u7075\u6d3b\u9002\u5408\u521d\u5b66\u8005\uff1b\u5927\u56de\u8f6c\u534a\u5f84\u66f4\u7a33\u5b9a\u9002\u5408\u8fdb\u9636\u8005\u3002</p>"},{"location":"03-%E6%BB%91%E9%9B%AA%E7%9F%A5%E8%AF%86/B-%E8%A3%85%E5%A4%87%E7%AF%87/1-%E5%8F%8C%E6%9D%BF%E9%9B%AA%E6%9D%BF/#_4","title":"\u5168\u5c71\u677f","text":"<p>\u8f83\u5e38\u89c1\u7684\u96ea\u677f\u7c7b\u578b\uff0c\u9002\u7528\u5927\u591a\u6570\u7684\u6ed1\u96ea\u98ce\u683c\uff0c\u4e2d\u7b49\u7684\u786c\u5ea6\u3001\u5bbd\u5ea6\u3001\u957f\u5ea6\uff0c\u53ef\u4ee5\u652f\u6301\u591a\u79cd\u6ed1\u96ea\u98ce\u683c\uff0c\u4e5f\u6709\u5f88\u597d\u7684\u64cd\u63a7\u6027\u3002</p>"},{"location":"03-%E6%BB%91%E9%9B%AA%E7%9F%A5%E8%AF%86/B-%E8%A3%85%E5%A4%87%E7%AF%87/1-%E5%8F%8C%E6%9D%BF%E9%9B%AA%E6%9D%BF/#_5","title":"\u91ce\u96ea\u677f/\u5927\u5c71\u677f","text":"<p>\u677f\u8170\u3001\u677f\u5934\u548c\u677f\u5c3e\u90fd\u6bd4\u5176\u4ed6\u96ea\u677f\u66f4\u5bbd\uff0c\u96ea\u8d8a\u6df1\u7684\u5730\u65b9\u8d8a\u9700\u8981\u53c8\u5bbd\u53c8\u957f\u7684\u96ea\u677f\uff0c\u6709\u8f83\u5927\u7684\u4fa7\u5203\u534a\u5f84\uff0c\u53ef\u4ee5\u6bd4\u8f83\u8f7b\u677e\u7684\u5f2f\u66f2\u3001\u56de\u8f6c\u3002</p>"},{"location":"03-%E6%BB%91%E9%9B%AA%E7%9F%A5%E8%AF%86/B-%E8%A3%85%E5%A4%87%E7%AF%87/1-%E5%8F%8C%E6%9D%BF%E9%9B%AA%E6%9D%BF/#_6","title":"\u81ea\u7531\u5f0f\u677f","text":"<p>\u677f\u5934\u548c\u677f\u5c3e\u5168\u90fd\u7fd8\u8d77\uff0c\u65b9\u4fbf\u5404\u79cd\u6b63\u6ed1\u548c\u5012\u6ed1\u6280\u5de7\u3002\u56fa\u5b9a\u5668\u7edd\u5bf9\u5c45\u4e2d\u5bf9\u79f0\u7684\u96ea\u677f\uff0c\u9002\u5408\u5728\u516c\u56ed\u91cc\u65bd\u5c55\u5404\u79cd\u6280\u5de7\u3002\u56fa\u5b9a\u5668\u504f\u5411\u4e8e\u677f\u5c3e\u4e14\u677f\u5c3e\u7565\u7a84\uff0c\u4e5f\u5f88\u597d\u7684\u517c\u987e\u4e86\u6ed1\u884c\u9700\u6c42\u3002</p>"},{"location":"03-%E6%BB%91%E9%9B%AA%E7%9F%A5%E8%AF%86/B-%E8%A3%85%E5%A4%87%E7%AF%87/1-%E5%8F%8C%E6%9D%BF%E9%9B%AA%E6%9D%BF/#_7","title":"\u957f\u5ea6","text":"<p>\u96ea\u677f\u957f\u5ea6\u76f4\u63a5\u5f71\u54cd\u8212\u9002\u611f\u548c\u63a7\u5236\u529b\uff1a</p> <ul> <li>\u77ed\u677f\u66f4\u52a0\u7075\u6d3b</li> <li>\u957f\u677f\u66f4\u52a0\u7a33\u5b9a</li> </ul> <p>\u96ea\u677f\u957f\u5ea6\u6839\u636e\u5ba1\u7a3f\u6d4b\u91cf\u773c\u775b\u9ad8\u5ea6\u4f5c\u4e3a\u57fa\u51c6\uff0c\u6d41\u4f20\u6700\u5e7f\u7684\u516c\u5f0f\u662f\uff1a</p> <ul> <li>\u96ea\u677f\u957f\u5ea6=\u8eab\u9ad8-(10~15cm)</li> </ul> <p>\u6839\u636e\u4ee5\u4e0b\u56e0\u7d20\u53ef\u4ee5\u5728\u57fa\u51c6\u957f\u5ea6\u4e0a\u9002\u5f53\u589e\u51cf\uff1a</p> <ul> <li>\u81ea\u8eab\u4f53\u91cd\uff1a\u504f\u8f7b-2cm\uff0c\u504f\u91cd+2cm</li> <li>\u6ed1\u884c\u98ce\u683c\uff1a\u5c0f\u5f2f-2cm\uff0c\u5927\u5f2f+2cm</li> <li>\u6ed1\u884c\u6c34\u5e73\uff1a\u521d\u7ea7-2cm\uff0c\u9ad8\u7ea7+2cm</li> <li>\u677f\u8eab\u5f62\u72b6\uff1a\u62f1\u5f62-2cm\uff0c\u4e0a\u7fd8+2cm</li> </ul>"},{"location":"03-%E6%BB%91%E9%9B%AA%E7%9F%A5%E8%AF%86/B-%E8%A3%85%E5%A4%87%E7%AF%87/1-%E5%8F%8C%E6%9D%BF%E9%9B%AA%E6%9D%BF/#_8","title":"\u677f\u8eab\u5f62\u72b6","text":""},{"location":"03-%E6%BB%91%E9%9B%AA%E7%9F%A5%E8%AF%86/B-%E8%A3%85%E5%A4%87%E7%AF%87/1-%E5%8F%8C%E6%9D%BF%E9%9B%AA%E6%9D%BF/#_9","title":"\u62f1\u5f62\u677f","text":"<p>\u5728\u9053\u5185\u53ef\u4ee5\u4e3a\u6ed1\u96ea\u8005\u63d0\u4f9b\u66f4\u597d\u7684\u7a33\u5b9a\u548c\u5438\u9707\uff0c\u4f7f\u6ed1\u96ea\u8005\u80fd\u66f4\u597d\u7684\u63a7\u5236\u677f\u5203\u3002</p>"},{"location":"03-%E6%BB%91%E9%9B%AA%E7%9F%A5%E8%AF%86/B-%E8%A3%85%E5%A4%87%E7%AF%87/1-%E5%8F%8C%E6%9D%BF%E9%9B%AA%E6%9D%BF/#_10","title":"\u4e0a\u7fd8\u677f","text":"<p>\u53ef\u4ee5\u5728\u91ce\u96ea\u6ed1\u884c\u4e2d\u63d0\u4f9b\u66f4\u5927\u6d6e\u529b\uff0c\u66f4\u597d\u5730\u5728\u7c89\u96ea\u6ed1\u884c\uff0c\u4f46\u662f\u8fd9\u79cd\u8bbe\u8ba1\u901a\u5e38\u4e0d\u5229\u4e8e\u96ea\u9053\u6ed1\u884c\u3002</p>"},{"location":"03-%E6%BB%91%E9%9B%AA%E7%9F%A5%E8%AF%86/B-%E8%A3%85%E5%A4%87%E7%AF%87/1-%E5%8F%8C%E6%9D%BF%E9%9B%AA%E6%9D%BF/#_11","title":"\u5e73\u76f4\u677f","text":"<p>\u6bd4\u8f83\u9002\u5408\u91ce\u96ea\u6ed1\u884c\uff0c\u4e5f\u6bd4\u8f83\u9002\u5408\u81ea\u7531\u5f0f\u6ed1\u884c\uff0c\u5bf9\u4fa7\u5203\u65bd\u52a0\u6bd4\u8f83\u5c0f\u7684\u529b\u4fbf\u53ef\u8f7b\u677e\u8f6c\u5f2f\u3002</p>"},{"location":"03-%E6%BB%91%E9%9B%AA%E7%9F%A5%E8%AF%86/B-%E8%A3%85%E5%A4%87%E7%AF%87/1-%E5%8F%8C%E6%9D%BF%E9%9B%AA%E6%9D%BF/#_12","title":"\u677f\u5934\u5f62\u72b6","text":""},{"location":"03-%E6%BB%91%E9%9B%AA%E7%9F%A5%E8%AF%86/B-%E8%A3%85%E5%A4%87%E7%AF%87/1-%E5%8F%8C%E6%9D%BF%E9%9B%AA%E6%9D%BF/#_13","title":"\u5c16\u5934\u677f","text":"<p>\u677f\u5934\u5448\u5c16\u9525\u5f62\uff0c\u51cf\u5c0f\u98ce\u963b\uff0c\u7cbe\u51c6\u5165\u5f2f\uff0c\u5e38\u89c1\u7528\u4e8e\u7ade\u901f\u7684\u9ad8\u901f\u5361\u5bbe\u677f\u3002</p>"},{"location":"03-%E6%BB%91%E9%9B%AA%E7%9F%A5%E8%AF%86/B-%E8%A3%85%E5%A4%87%E7%AF%87/1-%E5%8F%8C%E6%9D%BF%E9%9B%AA%E6%9D%BF/#_14","title":"\u5706\u5934\u677f","text":"<p>\u677f\u5934\u66f4\u5bbd\u66f4\u5706\uff0c\u63d0\u4f9b\u66f4\u5927\u6d6e\u529b\uff0c\u5165\u5f2f\u66f4\u67d4\u548c\uff0c\u5e38\u89c1\u4e8e\u5168\u5c71\u677f\u3001\u91ce\u96ea\u677f\u3002</p>"},{"location":"03-%E6%BB%91%E9%9B%AA%E7%9F%A5%E8%AF%86/B-%E8%A3%85%E5%A4%87%E7%AF%87/1-%E5%8F%8C%E6%9D%BF%E9%9B%AA%E6%9D%BF/#_15","title":"\u65b9\u5934\u677f","text":"<p>\u677f\u5934\u524d\u7aef\u6bd4\u8f83\u201c\u5e73\u201d\uff0c\u770b\u8d77\u6765\u50cf\u88ab\u524a\u5e73\u4e86\u4e00\u70b9\u3002\u5728\u4e0d\u589e\u52a0\u957f\u5ea6\u7684\u60c5\u51b5\u4e0b\u589e\u52a0\u63a5\u89e6\u9762\u79ef\uff0c\u964d\u4f4e\u91cd\u91cf\uff08\u53bb\u6389\u65e0\u6548\u957f\u5ea6\uff09\uff0c\u5e38\u89c1\u4e8e\u91ce\u96ea\u677f\u3002</p>"},{"location":"03-%E6%BB%91%E9%9B%AA%E7%9F%A5%E8%AF%86/C-%E6%8A%80%E6%9C%AF%E7%AF%87/1-%E5%8F%8C%E6%9D%BF%E6%8A%80%E6%9C%AF/","title":"\u53cc\u677f\u6280\u672f","text":""},{"location":"03-%E6%BB%91%E9%9B%AA%E7%9F%A5%E8%AF%86/C-%E6%8A%80%E6%9C%AF%E7%AF%87/1-%E5%8F%8C%E6%9D%BF%E6%8A%80%E6%9C%AF/#straight","title":"\u76f4\u7ebf\u6ed1\u884c(Straight)","text":""},{"location":"03-%E6%BB%91%E9%9B%AA%E7%9F%A5%E8%AF%86/C-%E6%8A%80%E6%9C%AF%E7%AF%87/1-%E5%8F%8C%E6%9D%BF%E6%8A%80%E6%9C%AF/#straight-down","title":"\u76f4\u6ed1\u964d(Straight Down)","text":""},{"location":"03-%E6%BB%91%E9%9B%AA%E7%9F%A5%E8%AF%8